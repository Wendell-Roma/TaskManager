@inject TaskManager.Web.Services.AuthService AuthService
@inject NavigationManager Nav

@if (AuthService.IsAuthenticated)
{
    <div class="top-bar">
        <span class="top-bar-brand">🗂️ TaskManager</span>
        <nav class="top-bar-nav">
            <NavLink href="/tasks" Match="NavLinkMatch.Prefix">Tarefas</NavLink>
        </nav>
        <button class="btn-logout" @onclick="Logout">Sair</button>
    </div>
}

@code {
    private void Logout()
    {
        AuthService.Logout();
        Nav.NavigateTo("/login");
    }
}