@page "/tasks"
@inject TaskManager.Web.Services.AuthService AuthService
@inject TaskManager.Web.Services.TaskService TaskService
@inject NavigationManager Nav

<div class="dashboard">
    <header class="dashboard-header">
        <h1>🗂️ TaskManager</h1>
        <div class="header-right">
            <span>Olá, <strong>@AuthService.UserName</strong></span>
            <button class="btn-logout" @onclick="Logout">Sair</button>
        </div>
    </header>

    <div class="dashboard-content">

        <!-- CONTADORES -->
        <div class="counters">
            <div class="counter-card total">
                <span class="counter-number">@tasks.Count</span>
                <span class="counter-label">Total</span>
            </div>
            <div class="counter-card pending">
                <span class="counter-number">@tasks.Count(t => !t.IsCompleted)</span>
                <span class="counter-label">Pendentes</span>
            </div>
            <div class="counter-card done">
                <span class="counter-number">@tasks.Count(t => t.IsCompleted)</span>
                <span class="counter-label">Concluídas</span>
            </div>
            <div class="counter-card overdue">
                <span class="counter-number">@tasks.Count(t => !t.IsCompleted && t.DueDate.HasValue && t.DueDate.Value < DateTime.Now)</span>
                <span class="counter-label">Atrasadas</span>
            </div>
        </div>

        <!-- FORMULÁRIO -->
        <div class="task-form-card">
            <h3>Nova Tarefa</h3>
            <div class="form-group">
                <input type="text" @bind="newTask.Title" placeholder="Título da tarefa" />
            </div>
            <div class="form-group">
                <input type="text" @bind="newTask.Description" placeholder="Descrição (opcional)" />
            </div>
            <div class="form-row">
                <select @bind="newTask.Priority">
                    <option value="1">🟢 Baixa</option>
                    <option value="2">🟡 Média</option>
                    <option value="3">🔴 Alta</option>
                </select>
                <input type="date" @bind="newTask.DueDate" />
            </div>
            <button class="btn-primary" @onclick="CreateTask" disabled="@isCreating">
                @(isCreating ? "Criando..." : "+ Adicionar Tarefa")
            </button>
        </div>

        <!-- FILTROS -->
        <div class="filters">
            <button class="filter-btn @(activeFilter == "all" ? "active" : "")" @onclick='() => SetFilter("all")'>
                Todas
            </button>
            <button class="filter-btn @(activeFilter == "pending" ? "active" : "")" @onclick='() => SetFilter("pending")'>
                Pendentes
            </button>
            <button class="filter-btn @(activeFilter == "done" ? "active" : "")" @onclick='() => SetFilter("done")'>
                Concluídas
            </button>
            <button class="filter-btn @(activeFilter == "high" ? "active" : "")" @onclick='() => SetFilter("high")'>
                🔴 Alta Prioridade
            </button>
            <button class="filter-btn @(activeFilter == "overdue" ? "active" : "")" @onclick='() => SetFilter("overdue")'>
                ⚠️ Atrasadas
            </button>
        </div>

        <!-- LISTA -->
        <div class="tasks-list">
            <div class="tasks-header">
                <h3>@GetFilterLabel() (@FilteredTasks.Count())</h3>
            </div>

            @if (isLoading)
            {
                <p class="loading">Carregando tarefas...</p>
            }
            else if (!FilteredTasks.Any())
            {
                <div class="empty-state">
                    <p>Nenhuma tarefa aqui. 🚀</p>
                </div>
            }
            else
            {
                @foreach (var task in FilteredTasks)
                {
                    <div class="task-card @(task.IsCompleted ? "completed" : "") priority-@task.Priority @(IsOverdue(task) ? "overdue-card" : "")">
                        <div class="task-check">
                            <input type="checkbox" checked="@task.IsCompleted"
                                   @onchange="() => ToggleComplete(task)" />
                        </div>
                        <div class="task-info">
                            <h4>@task.Title</h4>
                            @if (!string.IsNullOrEmpty(task.Description))
                            {
                                <p>@task.Description</p>
                            }
                            <div class="task-meta">
                                <span class="badge priority-badge-@task.Priority">
                                    @(task.Priority == 1 ? "Baixa" : task.Priority == 2 ? "Média" : "Alta")
                                </span>
                                @if (task.DueDate.HasValue)
                                {
                                    <span class="due-date @(IsOverdue(task) ? "overdue-text" : "")">
                                        📅 @task.DueDate.Value.ToString("dd/MM/yyyy")
                                        @if (IsOverdue(task)) { <span> ⚠️ Atrasada</span> }
                                    </span>
                                }
                            </div>
                        </div>
                        <button class="btn-delete" @onclick="() => DeleteTask(task.Id)">🗑️</button>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private List<TaskManager.Web.Models.TaskModel> tasks = new();
    private TaskManager.Web.Models.TaskRequest newTask = new();
    private bool isLoading = true;
    private bool isCreating = false;
    private string activeFilter = "all";

    private IEnumerable<TaskManager.Web.Models.TaskModel> FilteredTasks => activeFilter switch
    {
        "pending" => tasks.Where(t => !t.IsCompleted).OrderByDescending(t => t.Priority),
        "done" => tasks.Where(t => t.IsCompleted).OrderByDescending(t => t.CreatedAt),
        "high" => tasks.Where(t => t.Priority == 3 && !t.IsCompleted).OrderByDescending(t => t.DueDate),
        "overdue" => tasks.Where(t => IsOverdue(t)).OrderBy(t => t.DueDate),
        _ => tasks.OrderBy(t => t.IsCompleted).ThenByDescending(t => t.Priority)
    };

    private bool IsOverdue(TaskManager.Web.Models.TaskModel task) =>
        !task.IsCompleted && task.DueDate.HasValue && task.DueDate.Value < DateTime.Now;

    private void SetFilter(string filter) => activeFilter = filter;

    private string GetFilterLabel() => activeFilter switch
    {
        "pending" => "Pendentes",
        "done" => "Concluídas",
        "high" => "Alta Prioridade",
        "overdue" => "Atrasadas",
        _ => "Todas as Tarefas"
    };

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Nav.NavigateTo("/login");
            return;
        }
        await LoadTasks();
    }

    private async Task LoadTasks()
    {
        isLoading = true;
        tasks = await TaskService.GetTasksAsync();
        isLoading = false;
    }

    private async Task CreateTask()
    {
        if (string.IsNullOrWhiteSpace(newTask.Title)) return;
        isCreating = true;
        await TaskService.CreateTaskAsync(newTask);
        newTask = new();
        await LoadTasks();
        isCreating = false;
    }

    private async Task ToggleComplete(TaskManager.Web.Models.TaskModel task)
    {
        var request = new TaskManager.Web.Models.TaskRequest
        {
            Title = task.Title,
            Description = task.Description,
            Priority = task.Priority,
            DueDate = task.DueDate,
            IsCompleted = !task.IsCompleted
        };
        await TaskService.UpdateTaskAsync(task.Id, request);
        await LoadTasks();
    }

    private async Task DeleteTask(int id)
    {
        await TaskService.DeleteTaskAsync(id);
        await LoadTasks();
    }

    private void Logout()
    {
        AuthService.Logout();
        Nav.NavigateTo("/login");
    }
}